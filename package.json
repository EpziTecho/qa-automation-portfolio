{
  "name": "qa-automation-portfolio",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
  "cy:open": "cypress open",
  "cy:run": "cypress run",
  "test:smoke": "cypress run --spec \"cypress/e2e/smoke/**/*.cy.js\"",
  "test:regression": "cypress run --spec \"cypress/e2e/regression/**/*.cy.js\"",
  "allure:generate": "allure generate allure-results --clean -o allure-report",
  "allure:open": "allure open allure-report",
  "test:allure": "npm run cy:run && npm run allure:generate",
  "test:qa": "set CYPRESS_BASE_URL=https://www.saucedemo.com&& cypress run",
"test:qa:smoke": "set CYPRESS_BASE_URL=https://www.saucedemo.com&& cypress run --spec \"cypress/e2e/smoke/**/*.cy.js\"",
"test:qa:regression": "set CYPRESS_BASE_URL=https://www.saucedemo.com&& cypress run --spec \"cypress/e2e/regression/**/*.cy.js\""
},
